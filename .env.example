POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=learning-platform
POSTGRES_PORT=5432
# Set true for Neon and other cloud Postgres that require SSL
# POSTGRES_SSL_REQUIRE=false

# Optional: test DB name (default: {POSTGRES_DB}_test)
# POSTGRES_DB_TEST=learning-platform_test

# JWT: generate with `openssl rand -hex 32`
JWT_SECRET_KEY=your-secret-key-here

# FastAPI Users — generate each with: openssl rand -hex 32
AUTH_RESET_PASSWORD_TOKEN_SECRET=your-reset-secret-here
AUTH_VERIFICATION_TOKEN_SECRET=your-verification-secret-here

# CORS: "*" allows all origins (dev); comma-separated list for production (e.g. https://app.example.com)
# CORS_ORIGINS=*
# CORS_ORIGINS=http://localhost:3000,https://app.example.com
